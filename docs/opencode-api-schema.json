{
  "openapi": "3.1.0",
  "info": {
    "title": "ct_dev Agent Orchestrator MCP API",
    "description": "MCP Server for orchestrating specialized ct_dev-agents with session-based management",
    "version": "2.0.0",
    "contact": {
      "name": "X∞ System - Auctor"
    }
  },
  "servers": [
    {
      "url": "mcp://ct_dev-agent_orchestrator",
      "description": "MCP Server Endpoint"
    }
  ],
  "paths": {
    "/mcp/spawn_agent": {
      "post": {
        "operationId": "spawn_agent",
        "summary": "Spawn Specialized Agent Session",
        "description": "Spawns a specialized agent session for interactive work. Returns session_id for tracking and follow-up communication.",
        "tags": ["Agent Session Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SpawnAgentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent session spawned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionInfo"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/mcp/query_session": {
      "post": {
        "operationId": "query_session",
        "summary": "Query Agent Session Status",
        "description": "Gets current status of an agent session",
        "tags": ["Agent Session Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "session_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Session UUID"
                  }
                },
                "required": ["session_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session status retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionInfo"
                }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/mcp/get_agent_output": {
      "post": {
        "operationId": "get_agent_output",
        "summary": "Get Agent Session Output",
        "description": "Gets final output from completed agent session",
        "tags": ["Agent Session Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "session_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Session UUID"
                  }
                },
                "required": ["session_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent output retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentOutput"
                }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "400": {
            "description": "Session not completed yet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/mcp/list_active_sessions": {
      "post": {
        "operationId": "list_active_sessions",
        "summary": "List Active Agent Sessions",
        "description": "Lists all active agent sessions",
        "tags": ["Agent Session Management"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Active sessions retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SessionInfo"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/mcp/stop_agent": {
      "post": {
        "operationId": "stop_agent",
        "summary": "Stop Agent Session",
        "description": "Stops an agent session and cleans up resources",
        "tags": ["Agent Session Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "session_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Session UUID to stop"
                  }
                },
                "required": ["session_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent session stopped successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/mcp/send_to_agent": {
      "post": {
        "operationId": "send_to_agent",
        "summary": "Send Follow-up Message",
        "description": "Sends follow-up message to running agent session",
        "tags": ["Agent Session Management"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "session_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Session UUID"
                  },
                  "message": {
                    "type": "string",
                    "description": "Follow-up message"
                  }
                },
                "required": ["session_id", "message"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/mcp/get_agent_capabilities": {
      "post": {
        "operationId": "get_agent_capabilities",
        "summary": "Get Agent Capabilities",
        "description": "Gets information about available agent roles and capabilities",
        "tags": ["Agent Information"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent capabilities retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "roles": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AgentRole"
                      }
                    },
                    "count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/mcp/list_agents": {
      "post": {
        "operationId": "list_agents",
        "summary": "List All Agents",
        "description": "List all active agent instances",
        "tags": ["Agent Information"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent list retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentInstance"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/mcp/get_agent_stats": {
      "post": {
        "operationId": "get_agent_stats",
        "summary": "Get Agent Statistics",
        "description": "Get agent statistics (count by status, etc)",
        "tags": ["Agent Information"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent statistics retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentStats"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SpawnAgentRequest": {
        "type": "object",
        "required": [
          "role",
          "task_id",
          "instructions",
          "project_directory",
          "expected_output"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "backend_specialist",
              "bug_hunter",
              "code_reviewer",
              "database_architect",
              "devops_engineer",
              "documentation_specialist",
              "frontend_specialist",
              "generic_engineer",
              "integration_specialist",
              "performance_engineer",
              "product_manager",
              "project_architect",
              "quality_assurance",
              "refactoring_specialist",
              "research_specialist",
              "security_expert",
              "system_architect",
              "technical_writer"
            ],
            "description": "Specialized agent role"
          },
          "task_id": {
            "type": "string",
            "format": "uuid",
            "description": "Task UUID from task_orchestrator"
          },
          "instructions": {
            "type": "string",
            "description": "Detailed work instructions for the agent"
          },
          "project_directory": {
            "type": "string",
            "description": "Absolute path to project working directory"
          },
          "expected_output": {
            "type": "string",
            "description": "Expected work output/deliverable (e.g., 'Report', 'Implementation', 'Analysis')"
          },
          "context": {
            "type": "object",
            "additionalProperties": true,
            "description": "Additional context data",
            "default": {}
          },
          "model": {
            "type": "string",
            "description": "Model to use for the agent",
            "default": "claude-sonnet-4"
          }
        }
      },
      "SessionInfo": {
        "type": "object",
        "required": [
          "session_id",
          "agent_role",
          "status",
          "started_at",
          "server_url"
        ],
        "properties": {
          "session_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique session identifier"
          },
          "agent_role": {
            "type": "string",
            "description": "Agent role for this session"
          },
          "status": {
            "$ref": "#/components/schemas/SessionStatus"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "Session start timestamp"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "description": "Session completion timestamp",
            "nullable": true
          },
          "server_url": {
            "type": "string",
            "format": "uri",
            "description": "OpenCode server URL for this session"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Message"
            },
            "description": "Session message history"
          }
        }
      },
      "SessionStatus": {
        "type": "string",
        "enum": [
          "starting",
          "running",
          "completed",
          "failed",
          "stopped"
        ],
        "description": "Current status of agent session"
      },
      "AgentOutput": {
        "type": "object",
        "required": [
          "session_id",
          "status",
          "summary",
          "duration_seconds"
        ],
        "properties": {
          "session_id": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "$ref": "#/components/schemas/SessionStatus"
          },
          "summary": {
            "type": "string",
            "description": "Summary of agent work output"
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            },
            "description": "Generated artifacts (files, reports, etc.)"
          },
          "duration_seconds": {
            "type": "number",
            "format": "float",
            "description": "Total execution duration"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "Message": {
        "type": "object",
        "required": ["role", "parts"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["user", "assistant"]
          },
          "parts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "AgentRole": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AgentInstance": {
        "type": "object",
        "properties": {
          "agent_id": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["idle", "busy", "error"]
          },
          "port": {
            "type": "integer"
          },
          "pid": {
            "type": "integer"
          }
        }
      },
      "AgentStats": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "Total number of agents"
          },
          "by_status": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            },
            "description": "Count of agents grouped by status"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type/code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "details": {
            "type": "object",
            "additionalProperties": true,
            "description": "Additional error context"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Agent Session Management",
      "description": "Session-based agent lifecycle operations"
    },
    {
      "name": "Agent Information",
      "description": "Agent metadata and statistics"
    }
  ]
}
